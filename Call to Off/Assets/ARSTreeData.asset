  - nodeId: 0
    nodeName: "\uC2DC\uC791"
    nodeType: 0
    dialogue: "\uC548\uB155\uD558\uC138\uC694. \uC2A4\uB9C8\uC77C \uD648 \uD1B5\uD569
      \uACE0\uAC1D\uC9C0\uC6D0 ARS\uC785\uB2C8\uB2E4. \uC804\uD654 \uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4.\n\uD734\uB300\uD3F0 \uBC88\uD638 {PHONE_FULL}
      \uACE0\uAC1D\uB2D8,\n\uC694\uAE08 \uBB38\uC758\uB294 1\uBC88, \uC124\uCE58
      \uBC0F \uC774\uC804 \uBB38\uC758\uB294 2\uBC88, \uAC00\uC804 \uC6D0\uACA9 \uC81C\uC5B4
      \uBC0F \uC2A4\uB9C8\uD2B8\uD648 \uC11C\uBE44\uC2A4\uB294 3\uBC88, \uAE30\uD0C0\uBB38\uC758\uB294
      4\uBC88\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    choices:
    - inputKey: 1
      choiceText: "\uC694\uAE08 \uBB38\uC758"
      nextNodeId: 1
    - inputKey: 2
      choiceText: "\uC124\uCE58 \uBC0F \uC774\uC804 \uBB38\uC758"
