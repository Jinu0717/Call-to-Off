  - nodeId: 1
    nodeName: "\uC694\uAE08 \uBB38\uC758"
    nodeType: 0
    dialogue: "\uACE0\uAC1D\uB2D8\uC758 \uCF8C\uC801\uD55C \uC0DD\uD65C\uC744 \uC751\uC6D0\uD569\uB2C8\uB2E4.\n\uB2F9\uC6D4
      \uC804\uAE30\uC694\uAE08 \uC608\uC0C1 \uC870\uD68C\uB294 1\uBC88, \uB204\uC9C4\uC138
      \uAD6C\uAC04 \uC548\uB0B4\uB294 2\uBC88, \uC5EC\uB984\uCCA0 \uB0C9\uBC29\uAE30\uAE30
      \uC808\uC804 \uD301\uC740 3\uBC88\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694."
    choices:
    - inputKey: 1
      choiceText: "\uB2F9\uC6D4 \uC804\uAE30\uC694\uAE08 \uC608\uC0C1 \uC870\uD68C"
