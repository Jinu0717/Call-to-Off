  typeWriter: {fileID: 184504778}
  dialogues:
  - "\uD0C1\u2026 \uD0C1\u2026 \uD0C1\u2026"
  - "\uD558\u2026 \uB4DC\uB514\uC5B4 \uC549\uC558\uB2E4\u2026"
  - "\uC74C~ \uC774\uC81C \uD558\uC640\uC774\uB2E4\u2026"
  - "\uC774\uBC88\uC5D4 \uC9C4\uC9DC \uC544\uBB34 \uC0DD\uAC01 \uC5C6\uC774 \uC26C\uB294
    \uAC70\uC57C\u2026"
  - "\uC5B4\u2026?"
  - "\uC5B4?"
  - "\uC5B4???"
  - "\uC7A0\uAE50\uB9CC\u2026 \uC124\uB9C8\u2026"
  - "\u2026\uC5D0\uC5B4\uCEE8 \uC548 \uB044\uACE0 \uB098\uC654\uC796\uC544?!?!"
  - "\uC544\uB2C8 \uC65C \uC9C0\uAE08 \uC0DD\uAC01\uB098\uB0D0\uACE0!!"
  - "\uC5B4\uB5A1\uD558\uC9C0..."
  - "\uD558.. \uD070\uC77C\uB0AC\uB2E4 \uC9C4\uC9DC..."
  - "\uC774\uAC70 \uD558\uB8E8 \uC885\uC77C \uCF1C\uC838 \uC788\uC73C\uBA74\u2026"
  - "\uC804\uAE30\uC694\uAE08\u2026 \uB05D\uB0AC\uB124\u2026"
  - "\uC544\uB2C8\uC57C \uC544\uB2C8\uC57C, \uC544\uC9C1 \uBC29\uBC95 \uC788\uC744
    \uAC70\uC57C\u2026"
  - "\uC694\uC998\uC740 \uB2E4 \uC6D0\uACA9 \uB418\uC796\uC544\u2026"
  - "\uC544\u2026! ARS \uC11C\uBE44\uC2A4 \uC788\uC9C0?!!"
  - "\uADF8\uB798, \uC804\uD654\uB85C \uB04C \uC218 \uC788\uC744 \uAC70\uC57C\u2026"
  - "\uC81C\uBC1C\u2026 \uC5F0\uACB0\uB9CC \uC798 \uB418\uBA74 \uB41C\uB2E4\u2026"
